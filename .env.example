# ────────────────────────────────────────────
#  REBELLE STORE — Frontend env (example)
#  Copy to .env.local and fill real values.
#  Any NEXT_PUBLIC_* variable is shipped to the browser.
# ────────────────────────────────────────────

# ── Production ────────────────────────────────
# NEXT_PUBLIC_API_URL=https://api.rebelle.ma
# NEXT_PUBLIC_SITE_URL=https://rebelle.ma

# ── Local development ─────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Client-side pixels (leave empty if not in use)
NEXT_PUBLIC_FB_PIXEL_ID=
NEXT_PUBLIC_TT_PIXEL_ID=
NEXT_PUBLIC_SC_PIXEL_ID=
