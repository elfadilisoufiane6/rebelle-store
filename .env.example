# ────────────────────────────────────────────
#  REBELLE STORE — Frontend env (example)
#  Copy to .env.local and fill real values
#  Any NEXT_PUBLIC_* variable is shipped to the browser
# ────────────────────────────────────────────

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:3001

# Public site URL (used for canonical tags, OG metadata, sitemap)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Client-side pixels
NEXT_PUBLIC_FB_PIXEL_ID=
NEXT_PUBLIC_TT_PIXEL_ID=
NEXT_PUBLIC_SC_PIXEL_ID=
